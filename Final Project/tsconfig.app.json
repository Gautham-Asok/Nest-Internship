{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc",
    "rootDir": "./src",
    "types": []             // Clear this array entirely so it ignores Jasmine types
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"       // Keeps your testing files completely ignored by the build runner
  ]
}